# GroundsTruth DMS — environment variables (copy to .env.local; NEVER commit .env*)

# --- Supabase (browser-safe) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (SERVER-SIDE ONLY — never expose to the browser) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Integrations (server-side) ---
GOOGLE_MAPS_API_KEY=            # Phase 2 (GPS, PoD, beats)
RESEND_API_KEY=                 # email
META_WHATSAPP_TOKEN=            # alerts
META_WHATSAPP_PHONE_ID=

# --- App config ---
NEXT_PUBLIC_APP_NAME=GroundsTruth DMS
